###################################################################
# AI Dev Platform — Environment Configuration (v6+)
#
# Copy this file to .env and fill in values:
#   cp .env.example .env
#
# Core Principle:
#   Only the AI interface is stable.
#   Everything else is configurable and replaceable.
###################################################################

###################################################################
# 🧠 MODEL PROVIDER (logical intent layer)
#
# Controls routing + adapter selection via router.sh
#
# Options:
#   openai      → OpenAI API
#   http        → OpenAI-compatible endpoint
#   local       → Ollama / local LLM
#   goose       → Goose CLI runtime
#   mock        → Fully offline
###################################################################
MODEL_PROVIDER=openai

###################################################################
# 🔌 ADAPTER (execution layer override)
#
# Usually auto-managed by router.sh
#
# Options:
#   mock | http-agent | openai | goose | ollama
###################################################################
AI_ADAPTER=http-agent

###################################################################
# 🔁 FALLBACK CHAIN (CRITICAL — NEW)
#
# Ordered list of adapters to try when primary fails
#
# Examples:
#   mock only:
#     FALLBACK_CHAIN=mock
#
#   dev (offline → local → remote):
#     FALLBACK_CHAIN=mock,ollama,http-agent
#
#   prod (local → remote → openai):
#     FALLBACK_CHAIN=ollama,http-agent,openai
###################################################################
FALLBACK_CHAIN=mock,ollama,http-agent

# Enable/disable fallback system
FALLBACK_ENABLED=true

###################################################################
# 🌐 PRIMARY MODEL CONFIG (OpenAI / compatible)
###################################################################

OPENAI_API_KEY=

MODEL_NAME=gpt-4o-mini

# Default HTTP endpoint
MODEL_ENDPOINT=

# Examples:
# MODEL_ENDPOINT=https://api.openai.com/v1
# MODEL_ENDPOINT=http://127.0.0.1:8000/v1

###################################################################
# 🏠 LOCAL LLM (OLLAMA) CONFIG — NEW
###################################################################

# Ollama endpoint (non-OpenAI format)
OLLAMA_ENDPOINT=http://ollama:11434

# Model installed via: ollama pull llama3
OLLAMA_MODEL=tinyllama

# Optional OpenAI-compatible Ollama endpoint
# (only if using http-agent instead of ollama adapter)
OLLAMA_OPENAI_ENDPOINT=http://ollama:11434/v1

###################################################################
# 🧪 MOCK / FALLBACK SERVER CONFIG — NEW
###################################################################

# Used by _base.sh fallback handler
FALLBACK_ENDPOINT=http://127.0.0.1:8000/v1
FALLBACK_MODEL=mock-model

###################################################################
# 🪿 GOOSE CONFIG
###################################################################

GOOSE_BIN=goose

# Goose uses OpenAI-compatible providers
# Must align with MODEL_PROVIDER=openai
GOOSE_MODEL=gpt-4o-mini

###################################################################
# ⚙️ ADAPTER BEHAVIOR
###################################################################

AI_STREAM=false
AI_JSON_MODE=false
AI_RETRIES=3
AI_TIMEOUT=30

MODEL_TEMPERATURE=0.7
MODEL_MAX_TOKENS=512

###################################################################
# 📦 PROJECT CONTEXT
###################################################################

ACTIVE_PROJECT=

# Examples:
# ACTIVE_PROJECT=agent-sim
# ACTIVE_PROJECT=arb-agent-system

###################################################################
# 🧪 DEBUG / DEVELOPMENT
###################################################################

AI_DEBUG=false
AI_RAW_OUTPUT=false

# Logs fallback decisions
AI_DEBUG_FALLBACK=false