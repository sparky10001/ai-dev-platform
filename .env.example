###################################################################
# AI Dev Platform — Environment Configuration
# Copy this file to .env and fill in your values
#   cp .env.example .env
#
# Core Principle: Only the AI interface is stable.
# Everything else can change, will change, should be replaceable.
###################################################################

###################################################################
# AI Provider
# Options: openai | colab | local | mock
#
#   openai  → OpenAI API (requires OPENAI_API_KEY)
#   colab   → Google Colab GPU proxy (requires COLAB_URL)
#   local   → Local model via private-ai-stack or Ollama
#   mock    → Offline/testing mode — no AI calls made
###################################################################
MODEL_PROVIDER=openai

###################################################################
# Active Adapter
# Options: goose | mock
# Controls which adapter script ai.sh symlinks to
###################################################################
AI_ADAPTER=goose

###################################################################
# OpenAI Configuration
# Required when MODEL_PROVIDER=openai
###################################################################
OPENAI_API_KEY=

###################################################################
# Colab Configuration
# Required when MODEL_PROVIDER=colab
# Set COLAB_URL to your ngrok or Colab proxy endpoint
###################################################################
COLAB_URL=
# MODEL_ENDPOINT=$COLAB_URL/v1

###################################################################
# Local Configuration
# Required when MODEL_PROVIDER=local
# Point to your private-ai-stack or Ollama instance
###################################################################
# MODEL_ENDPOINT=http://localhost:11434/v1
# MODEL_ENDPOINT=http://192.168.163.135:11434/v1

###################################################################
# Model Selection (optional)
# Defaults to provider default if not set
###################################################################
# GOOSE_MODEL=claude-3-5-sonnet
# GOOSE_MODEL=gpt-4o
# GOOSE_MODEL=phi3

###################################################################
# Project Context (optional)
# Helps AI understand which project you are working in
###################################################################
# ACTIVE_PROJECT=agent-sim
# ACTIVE_PROJECT=arb-agent-system
# ACTIVE_PROJECT=private-ai-stack
