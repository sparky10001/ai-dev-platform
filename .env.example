###################################################################
# AI Dev Platform — Environment Configuration (v7)
#
# Copy this file to .env and fill in values:
#   cp .env.example .env
#
# Architecture:
#   ai → router → litellm → providers (ollama/openai/etc.)
#
# Core Principle:
#   LiteLLM is the routing layer.
#   Adapters are thin (or removed).
###################################################################

###################################################################
# 🧠 PROVIDER (logical layer)
#
# Controls which execution path is used
#
# Options:
#   litellm   → Primary (recommended)
#   goose     → Agent layer (optional)
#   mock      → Offline / testing
###################################################################
MODEL_PROVIDER=litellm

###################################################################
# 🔌 ADAPTER (execution layer)
#
# Should almost always be:
#   litellm
###################################################################
AI_ADAPTER=litellm

###################################################################
# 🎯 ACTIVE MODEL (PRIMARY CONTROL)
#
# This is what actually changes behavior.
#
# Examples:
#   fast     → low latency (tinyllama / small models)
#   code     → stronger reasoning
#   claude   → Claude-style models via LiteLLM
#   general  → balanced default
###################################################################
ACTIVE_MODEL=fast

###################################################################
# 🔁 FALLBACK (SIMPLIFIED)
#
# LiteLLM already handles provider fallback internally.
# This is only a LAST RESORT safety net.
#
# Recommended:
#   mock only
###################################################################
FALLBACK_CHAIN=mock
FALLBACK_ENABLED=true

###################################################################
# 🌐 LITELLM CONFIG (PRIMARY RUNTIME)
###################################################################

LITELLM_BASE_URL=http://litellm:4000/v1
LITELLM_MASTER_KEY=ai-dev-platform

###################################################################
# 🏠 OLLAMA (LOCAL MODEL BACKEND)
#
# Used by LiteLLM — NOT directly by adapters
###################################################################

OLLAMA_ENDPOINT=http://ollama:11434
OLLAMA_MODEL=tinyllama

###################################################################
# ☁️ OPENAI (OPTIONAL BACKEND FOR LITELLM)
###################################################################

OPENAI_API_KEY=

###################################################################
# 🪿 GOOSE (AGENT LAYER — OPTIONAL)
#
# Goose should point to LiteLLM, not OpenAI directly
###################################################################

GOOSE_ENABLED=true
GOOSE_PROVIDER=litellm
GOOSE_MODEL=fast

# Optional overrides (usually not needed)
LITELLM_HOST=http://litellm:4000
LITELLM_TIMEOUT=180

###################################################################
# ⚙️ RUNTIME BEHAVIOR
###################################################################

AI_TIMEOUT=60
AI_RETRIES=2

AI_STREAM=false
AI_JSON_MODE=false

MODEL_TEMPERATURE=0.7
MODEL_MAX_TOKENS=512

###################################################################
# 📦 PROJECT CONTEXT
###################################################################

ACTIVE_PROJECT=

# Examples:
# ACTIVE_PROJECT=agent-sim
# ACTIVE_PROJECT=arb-agent-system

###################################################################
# 🧪 DEBUG / DEVELOPMENT
###################################################################

AI_DEBUG=false
AI_RAW_OUTPUT=false
AI_DEBUG_FALLBACK=false