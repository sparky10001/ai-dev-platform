###################################################################
# AI Dev Platform — Environment Configuration
#
# Copy this file to .env and fill in values:
#   cp .env.example .env
#
# Core Principle:
#   Only the AI interface is stable.
#   Everything else is configurable and replaceable.
###################################################################

###################################################################
# MODEL PROVIDER (where the model runs)
#
# Options:
#   openai      → OpenAI API
#   colab       → Google Colab / ngrok proxy
#   local       → Ollama / private-ai-stack
#   mock        → Offline mode (no API calls)
#   mock-local  → Local mock OpenAI-compatible server
###################################################################
MODEL_PROVIDER=openai

###################################################################
# Adapter Selection (execution layer)
# Options: mock | http-agent | goose | openai
#
# mock        → no network
# http-agent  → curl only (no dependencies)
# goose       → Goose agent runtime
# openai      → direct OpenAI adapter
###################################################################
AI_ADAPTER=http-agent

###################################################################
# OPENAI / OPENAI-COMPATIBLE CONFIG
#
# Used by:
#   - openai adapter
#   - goose adapter (via config)
#
# Required when:
#   MODEL_PROVIDER=openai OR using compatible endpoints
###################################################################
OPENAI_API_KEY=

# Model selection
MODEL_NAME=gpt-4o-mini

# Endpoint override (optional)
# Use for:
#   - mock-local
#   - colab proxy
#   - local OpenAI-compatible APIs
#
# Examples:
# MODEL_ENDPOINT=http://127.0.0.1:8000/v1
# MODEL_ENDPOINT=http://localhost:11434/v1
MODEL_ENDPOINT=

###################################################################
# COLAB CONFIGURATION (optional)
###################################################################
COLAB_URL=
# MODEL_ENDPOINT=$COLAB_URL/v1

###################################################################
# LOCAL MODEL CONFIGURATION (optional)
#
# Example (Ollama):
# MODEL_ENDPOINT=http://localhost:11434/v1
###################################################################

###################################################################
# ADAPTER BEHAVIOR
###################################################################

# Streaming output (true/false)
AI_STREAM=false

# Force JSON responses (true/false)
AI_JSON_MODE=false

# Retry attempts on failure
AI_RETRIES=3

# Temperature (creativity)
MODEL_TEMPERATURE=0.7

# Max tokens per response
MODEL_MAX_TOKENS=512

###################################################################
# GOOSE-SPECIFIC CONFIG (optional)
###################################################################

# Example:
# GOOSE_MODEL=claude-3-5-sonnet
# GOOSE_MODEL=gpt-4o
# GOOSE_MODEL=phi3

###################################################################
# PROJECT CONTEXT (optional)
#
# Injected into prompts by adapters
###################################################################
ACTIVE_PROJECT=

# Examples:
# ACTIVE_PROJECT=agent-sim
# ACTIVE_PROJECT=arb-agent-system
# ACTIVE_PROJECT=private-ai-stack

###################################################################
# DEBUG / DEVELOPMENT
###################################################################

# Enable verbose logging
AI_DEBUG=false

# Show raw API responses
AI_RAW_OUTPUT=false