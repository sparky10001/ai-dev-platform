{
  "name": "AI Dev Environment",

  // ----------------------------------------------------------------
  // Build
  // ----------------------------------------------------------------
  "build": {
    "dockerfile": "Dockerfile"
  },

  // ----------------------------------------------------------------
  // User
  // ----------------------------------------------------------------
  "remoteUser": "vscode",

  // ----------------------------------------------------------------
  // Container args
  // ----------------------------------------------------------------
  "runArgs": [
    // Maps host.docker.internal → host machine (portable, no hardcoded IPs)
    "--add-host=host.docker.internal:host-gateway",

    // Mount Docker socket for Docker-outside-of-Docker (DooD)
    // Allows: docker compose, make up, etc. from inside container
    "--volume=/var/run/docker.sock:/var/run/docker.sock"
  ],

  // ----------------------------------------------------------------
  // Mounts
  // ----------------------------------------------------------------
  "mounts": [
    // Workspace mount — bind to host repo
    "source=/home/labadmin/ai-dev-platform,target=/workspace,type=bind,consistency=cached"
  ],

  // ----------------------------------------------------------------
  // Lifecycle hooks
  // ----------------------------------------------------------------
  "postCreateCommand": "/bin/bash .devcontainer/post-create.sh",

  // ----------------------------------------------------------------
  // VS Code customizations
  // ----------------------------------------------------------------
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-vscode-remote.remote-containers",
        "ms-python.python",
        "esbenp.prettier-vscode",
        "ms-azuretools.vscode-docker"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/opt/venv/bin/python",
        "python.terminal.activateEnvironment": true,
        "editor.tabSize": 2,
        "editor.insertSpaces": true,
        "editor.formatOnSave": true
      }
    }
  },

  // ----------------------------------------------------------------
  // Port forwarding
  // ----------------------------------------------------------------
  "forwardPorts": [
    3000,    // General app port
    11434,   // Ollama LLM service
    8000     // Mock OpenAI server / agent-sim env server
  ],

  // ----------------------------------------------------------------
  // Remote environment
  // ----------------------------------------------------------------
  "remoteEnv": {
    // PATH — includes venv and local bins
    "PATH": "/opt/venv/bin:/usr/local/bin:${containerEnv:PATH}",

    // Ollama — portable via host.docker.internal (no hardcoded IPs)
    "OLLAMA_ENDPOINT": "http://host.docker.internal:11434",
    "OLLAMA_MODEL": "tinyllama",

    // AI Platform defaults
    "MODEL_PROVIDER": "ollama",
    "AI_ADAPTER": "ollama"
  }
}
