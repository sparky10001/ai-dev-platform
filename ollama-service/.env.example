###################################################################
# Ollama Service — Environment Configuration
###################################################################

# ---- Port ----
OLLAMA_PORT=11434

# ---- Default model (pulled on first start) ----
DEFAULT_MODEL=tinyllama

# ---- Extra models (comma separated, pulled after default) ----
# EXTRA_MODELS=phi3,llama3.2
EXTRA_MODELS=

# ---- Startup wait (seconds) ----
OLLAMA_STARTUP_WAIT=60

# ---- Performance ----
# CPU threads (0 = auto)
OLLAMA_NUM_THREAD=0

# Keep model loaded in memory (seconds, -1 = forever, 0 = unload immediately)
OLLAMA_KEEP_ALIVE=300

# ---- Resource limits ----
# Tuned for Y510P 8GB RAM — adjust for your hardware
OLLAMA_MEMORY_LIMIT=4g
OLLAMA_MEMORY_RESERVE=1g
