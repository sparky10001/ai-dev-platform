#!/bin/bash
###################################################################
# ai — Stable AI Interface (Runtime v5.5)
#
# Improvements:
#   - Structured tool result injection (JSON)
#   - Single-pass JSON parsing (performance)
#   - Structured trace logging (optional)
#   - Stronger tool validation
###################################################################

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ENV_FILE="${SCRIPT_DIR}/../.env"
ADAPTERS_DIR="${SCRIPT_DIR}/adapters"
TOOL_EXECUTOR="${SCRIPT_DIR}/../runtime/tool_executor.sh"
TRACE_LOG="${SCRIPT_DIR}/../.ai_trace.log"

# ---- Load environment safely ----
if [ -f "$ENV_FILE" ]; then
    set -a
    source "$ENV_FILE"
    set +a
fi

# ---- Args ----
COMMAND=${1:-}
shift || true

if [ -z "$COMMAND" ]; then
    echo "Usage: ai [run|explain|refactor|fix|query] <args>"
    echo ""
    echo "Options:"
    echo "  --trace           Show execution steps"
    echo "  --max-steps=N     Limit execution loop (default: 1)"
    echo "  --budget=N        Max iterations allowed"
    exit 1
fi

# ---- Defaults ----
TRACE=0
MAX_STEPS=1
BUDGET=""
AI_TIMEOUT="${AI_TIMEOUT:-30}"

# ---- Parse flags ----
ARGS=()

while [[ $# -gt 0 ]]; do
    case $1 in
        --trace)
            TRACE=1
            shift
            ;;
        --max-steps=*)
            MAX_STEPS="${1#*=}"
            shift
            ;;
        --budget=*)
            BUDGET="${1#*=}"
            shift
            ;;
        *)
            ARGS+=("$1")
            shift
            ;;
    esac
done

INPUT="${ARGS[*]}"

# ---- Adapter selection ----
ADAPTER_NAME="${AI_ADAPTER:-goose}"
ADAPTER="${ADAPTERS_DIR}/${ADAPTER_NAME}.sh"

if [ ! -f "$ADAPTER" ]; then
    echo "❌ Adapter not found: $ADAPTER_NAME"
    echo "Expected: $ADAPTER"
    exit 1
fi

# ---- JSON helpers (single-pass safe) ----
parse_json() {
    echo "$1" | jq -e . 2>/dev/null || return 1
}

json_get() {
    local expr="$1"
    echo "$PARSED_JSON" | jq -r "$expr // empty"
}

# ---- Trace logging (structured) ----
log_event() {
    local event="$1"
    local data="$2"

    jq -n \
      --arg step "$step" \
      --arg event "$event" \
      --arg data "$data" \
      '{
        step: ($step | tonumber),
        event: $event,
        data: $data,
        timestamp: now
      }' >> "$TRACE_LOG" 2>/dev/null || true
}

# ---- Runtime execution engine ----
runtime_execute() {
    local command="$1"
    local input="$2"

    local step=1
    local raw_output=""
    local status=""
    local clean_output=""
    local next_input=""
    local tool_name=""
    local tool_input=""
    local last_tool=""
    local PARSED_JSON=""

    while [ "$step" -le "$MAX_STEPS" ]; do

        if [ -n "$BUDGET" ] && [ "$step" -gt "$BUDGET" ]; then
            [ "$TRACE" -eq 1 ] && echo "⚠️ Budget limit reached"
            break
        fi

        [ "$TRACE" -eq 1 ] && echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
        [ "$TRACE" -eq 1 ] && echo "🔁 Step $step / $MAX_STEPS"
        [ "$TRACE" -eq 1 ] && echo "📥 Input: $input"

        log_event "step_start" "$input"

        # ---- Execute adapter ----
        if ! raw_output=$(timeout "$AI_TIMEOUT" "$ADAPTER" "$command" "$input"); then
            echo "❌ Adapter failed or timed out (${AI_TIMEOUT}s)"
            log_event "adapter_error" "timeout_or_failure"
            exit 1
        fi

        [ -z "$raw_output" ] && break

        # ---- Parse JSON once ----
        if PARSED_JSON=$(parse_json "$raw_output"); then
            status=$(json_get '.status')
            clean_output=$(json_get '.output')
            next_input=$(json_get '.next_input')
            tool_name=$(json_get '.tool_call.name')
            tool_input=$(echo "$PARSED_JSON" | jq -c '.tool_call.input // {}')
        else
            status="done"
            clean_output="$raw_output"
            next_input=""
            tool_name=""
        fi

        [ "$TRACE" -eq 1 ] && echo "📤 Output: $clean_output"
        [ "$TRACE" -eq 1 ] && echo "📊 Status: ${status:-done}"

        log_event "adapter_output" "$clean_output"

        # ==========================================================
        # 🔥 TOOL EXECUTION BLOCK (v5.5 upgraded)
        # ==========================================================
        if [ "$status" = "tool_call" ]; then

            if [ -z "$tool_name" ] || [ "$tool_name" = "null" ]; then
                echo "❌ Invalid tool call (missing name)"
                log_event "tool_error" "missing_name"
                return 1
            fi

            # ---- Loop protection ----
            if [ "$tool_name" = "$last_tool" ]; then
                echo "⚠️ Repeated tool call detected: $tool_name"
                log_event "tool_loop_detected" "$tool_name"
                return 1
            fi

            last_tool="$tool_name"

            [ "$TRACE" -eq 1 ] && echo "🛠️ Tool call: $tool_name"
            [ "$TRACE" -eq 1 ] && echo "📦 Input: $tool_input"

            log_event "tool_call" "$tool_name"

            if [ ! -f "$TOOL_EXECUTOR" ]; then
                echo "❌ Tool executor not found"
                return 1
            fi

            # ---- Execute tool ----
            if ! TOOL_RESULT=$(bash "$TOOL_EXECUTOR" "$tool_name" "$tool_input"); then
                echo "❌ Tool execution failed"
                log_event "tool_error" "execution_failed"
                return 1
            fi

            [ "$TRACE" -eq 1 ] && echo "📤 Tool result:"
            [ "$TRACE" -eq 1 ] && echo "$TOOL_RESULT"

            log_event "tool_result" "$TOOL_RESULT"

            # ---- Normalize tool output ----
            if parse_json "$TOOL_RESULT" >/dev/null 2>&1; then
                tool_output=$(echo "$TOOL_RESULT" | jq -r '.output // .')
            else
                tool_output="$TOOL_RESULT"
            fi

            # ---- Structured injection (CRITICAL FIX) ----
            input=$(jq -n \
              --arg tool "$tool_name" \
              --arg result "$tool_output" \
              --arg command "$command" \
              '{
                type: "tool_result",
                tool: $tool,
                result: $result,
                next_task: $command
              }')

            ((step++))
            continue
        fi
        # ==========================================================

        # ---- Execution state machine ----
        case "${status:-done}" in

            done)
                [ "$TRACE" -eq 0 ] && echo "$clean_output"
                return 0
                ;;

            error)
                echo "❌ Adapter error:"
                echo "$clean_output"
                return 1
                ;;

            continue|running)
                if [ -n "$next_input" ]; then
                    input="$next_input"
                else
                    input="$clean_output"
                fi
                ;;

            *)
                echo "⚠️ Unknown status: $status"
                echo "$clean_output"
                return 1
                ;;
        esac

        ((step++))
    done

    echo "$clean_output"
}

# ---- Execute ----
runtime_execute "$COMMAND" "$INPUT"