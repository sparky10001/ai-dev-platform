###################################################################
# LiteLLM Service — Environment Configuration
###################################################################

# ---- Port ----
LITELLM_PORT=4000

# ---- Master key (used as Bearer token for API calls) ----
LITELLM_MASTER_KEY=ai-dev-platform

# ---- Active model alias (maps to config.yaml) ----
# Options: fast | general | code | tooling | claude | smart
ACTIVE_MODEL=fast

# ---- Ollama connection ----
# Uses Docker DNS — resolves http://ollama:11434 automatically
# Change only if Ollama is running outside Docker
OLLAMA_BASE_URL=http://ollama:11434

# ---- OpenAI (optional — enables code/tooling/smart models) ----
OPENAI_API_KEY=

# ---- Anthropic/Claude (optional — enables claude/smart models) ----
ANTHROPIC_API_KEY=

# ---- Startup wait (seconds to wait for Ollama) ----
LITELLM_STARTUP_WAIT=60

# ---- Resource limits ----
LITELLM_MEMORY_LIMIT=512m
